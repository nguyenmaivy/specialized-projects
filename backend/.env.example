# ─── Server Settings ───────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Authentication ───────────────────────────────────────────────────────────
# Set to "true" to require JWT for all /api/* endpoints
AUTH_REQUIRED=false
SECRET_KEY=change-this-to-a-strong-random-key-in-production
TOKEN_EXPIRE_MINUTES=60

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT=100/minute

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sales_dashboard
POSTGRES_USER=sales_user
POSTGRES_PASSWORD=123456
# Optional full DSN (overrides vars above)
# POSTGRES_DSN=postgresql+psycopg://sales_user:sales_password@localhost:5432/sales_dashboard

# ─── OpenRouter / OpenAI (compatible) ───────────────────────────────────────────
# Prefer OPENROUTER_API_KEY for OpenRouter deployments. OPENAI_API_KEY is also supported.
OPENROUTER_API_KEY=sk-....
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
